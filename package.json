{
  "name": "my-nestjs-microservices",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api-gateway/main",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/api-gateway/test/jest-e2e.json",
    "type-check": "tsc --noEmit",
    "start:gateway": "nest start api-gateway --watch",
    "start:auth": "nest start auth-service --watch",
    "start:user": "nest start user-service --watch",
    "start:email": "nest start email-service --watch",
    "start:log": "nest start log-service --watch",
    "start:product": "nest start product-service --watch",
    "start:media": "nest start media-service --watch",
    "start:content": "nest start content-service --watch",
    "prisma:generate:auth": "prisma generate --config=apps/auth-service/prisma.config.ts",
    "prisma:generate:user": "prisma generate --config=apps/user-service/prisma.config.ts",
    "prisma:generate:product": "prisma generate --config=apps/product-service/prisma.config.ts",
    "prisma:generate:media": "prisma generate --config=apps/media-service/prisma.config.ts",
    "prisma:generate:content": "prisma generate --config=apps/content-service/prisma.config.ts",
    "prisma:generate": "pnpm prisma:generate:auth && pnpm prisma:generate:user",
    "prisma:migrate:auth": "prisma migrate dev --config=apps/auth-service/prisma.config.ts --name",
    "prisma:migrate:user": "prisma migrate dev --config=apps/user-service/prisma.config.ts --name",
    "prisma:migrate:product": "prisma migrate dev --config=apps/product-service/prisma.config.ts --name",
    "prisma:migrate:media": "prisma migrate dev --config=apps/media-service/prisma.config.ts --name",
    "prisma:migrate:content": "prisma migrate dev --config=apps/content-service/prisma.config.ts --name",
    "prisma:deploy:auth": "prisma migrate deploy --config=apps/auth-service/prisma.config.ts",
    "prisma:deploy:user": "prisma migrate deploy --config=apps/user-service/prisma.config.ts",
    "prisma:studio:auth": "prisma studio --config=apps/auth-service/prisma.config.ts",
    "prisma:studio:user": "prisma studio --config=apps/user-service/prisma.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.6.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/instrumentation-amqplib": "^0.43.0",
    "@opentelemetry/instrumentation-express": "^0.47.1",
    "@opentelemetry/instrumentation-http": "^0.57.2",
    "@opentelemetry/instrumentation-ioredis": "^0.62.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.45.0",
    "@opentelemetry/instrumentation-pg": "^0.66.0",
    "@opentelemetry/instrumentation-redis-4": "^0.49.0",
    "@opentelemetry/resources": "^1.27.0",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@opentelemetry/sdk-trace-base": "^1.27.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@prisma/instrumentation": "^7.6.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^5.2.1",
    "ioredis": "^5.4.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^7.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/common(|/.*)$": "<rootDir>/libs/common/src/$1"
    }
  }
}
