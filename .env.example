# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000
APP_LOGO_URL=https://nestjs.com/img/logo-small.svg
ENABLE_SWAGGER=false

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBIT_MQ_URI=amqp://user:password@localhost:5672
RABBIT_MQ_USER_SERVICE_QUEUE=user_queue
RABBIT_MQ_LOG_SERVICE_QUEUE=log_queue
RABBIT_MQ_AUTH_SERVICE_QUEUE=auth_queue
RABBIT_MQ_EMAIL_SERVICE_QUEUE=email_queue
RABBIT_MQ_PRODUCT_SERVICE_QUEUE=product_queue
RABBIT_MQ_MEDIA_SERVICE_QUEUE=media_queue

# OPEN TELEMETRY
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── PostgreSQL — Tách riêng DB cho từng service để tránh xung đột Migration ────
#
#  nest_mcr_auth:    chứa bảng đăng nhập, token, phân quyền (auth-service)
#  nest_mcr_user:    chứa bảng hồ sơ người dùng (user-service)
#  nest_mcr_product: chứa bảng sản phẩm (product-service)
#
AUTH_DATABASE_URL=postgresql://user:password@localhost:5432/nest_mcr_auth
USER_DATABASE_URL=postgresql://user:password@localhost:5432/nest_mcr_user
PRODUCT_DATABASE_URL=postgresql://user:password@localhost:5432/nest_mcr_product
MEDIA_DATABASE_URL=postgresql://user:password@localhost:5432/media_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email / SMTP (dùng bởi email-service) ────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME="Nest Microservices" <no-reply-nestjs-microservice@gmail.com>

# ─── AWS ──────────────────────────────────────────────
AWS_REGION=hn
AWS_ENDPOINT=https://hn.ss.bfcplatform.vn
AWS_ACCESS_KEY_ID=PB2E0IEPAP98LDX7KLLL
AWS_SECRET_KEY=xxx
AWS_S3_BUCKET_NAME=xx