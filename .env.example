# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000
APP_LOGO_URL=https://nestjs.com/img/logo-small.svg
ENABLE_SWAGGER=false

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBIT_MQ_URI=amqp://user:password@localhost:5672
RABBIT_MQ_USER_SERVICE_QUEUE=user_queue
RABBIT_MQ_LOG_SERVICE_QUEUE=log_queue
RABBIT_MQ_AUTH_SERVICE_QUEUE=auth_queue
RABBIT_MQ_EMAIL_SERVICE_QUEUE=email_queue

# ─── PostgreSQL — cùng 1 DB "nestjs_microservices", khác schema ───────────────
#
#  Cấu trúc trong Postgres:
#   nestjs_microservices
#   ├── schema: auth    → bảng users          (auth-service)
#   └── schema: users   → bảng user_profiles  (user-service)
#
#  Schema được khai báo trong Prisma qua @@schema() + multiSchema preview feature.
#  Prisma tự chạy CREATE SCHEMA IF NOT EXISTS khi migrate.
#  KHÔNG cần ?schema= trong URL — Prisma 7 + adapter-pg xử lý qua prisma.config.ts
#
DATABASE_URL=postgresql://user:password@localhost:5432/nestjs_microservices

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email / SMTP (dùng bởi email-service) ────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=My App
