// Prisma 7: datasource URL được inject qua prisma.config.ts (không khai báo url ở đây)
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Media {
  id           String      @id @default(uuid())
  path         String      @unique // S3 key
  originalName String
  mimeType     String
  size         Int
  status       MediaStatus @default(PENDING)

  // Quan hệ với resource bên ngoài
  referType ReferType?
  referId   String?

  uploadedByUserId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([path])
  @@index([status])
  @@index([uploadedByUserId])
  @@map("media")
}

enum MediaStatus {
  PENDING
  USED
  UNUSED
}

enum ReferType {
  USER_AVATAR
  POST_THUMBNAIL
  PRODUCT_IMAGE
  TEMP
}
