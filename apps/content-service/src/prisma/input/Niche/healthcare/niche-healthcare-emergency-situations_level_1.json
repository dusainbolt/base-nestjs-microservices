{
  "l": 1,
  "d": [
    {
      "t": "Gọi giúp khẩn cấp",
      "e": [
        {
          "p": "What is the emergency?",
          "m": "Nói 1 câu: vấn đề chính là gì.",
          "h": "S + be + N/Adj hoặc S + V(s) + O",
          "s": "A man is hurt."
        },
        {
          "p": "Where are you now?",
          "m": "Nói nơi bạn ở ngắn gọn.",
          "h": "S + be + place",
          "s": "I am at the house."
        },
        {
          "p": "How many people are hurt?",
          "m": "Nói số người bị thương.",
          "h": "There is/There are + number",
          "s": "There are two people hurt."
        },
        {
          "p": "Can you move the injured person?",
          "m": "Nói có hoặc không bạn có thể di chuyển người đó.",
          "h": "S + can/can't + V",
          "s": "I can't move him."
        },
        {
          "p": "Do you need an ambulance?",
          "m": "Trả lời có hoặc không.",
          "h": "Yes/No + S + V",
          "s": "Yes, we need an ambulance."
        }
      ]
    },
    {
      "t": "Mô tả vết thương",
      "e": [
        {
          "p": "Where is the wound?",
          "m": "Nói vị trí vết thương trên cơ thể.",
          "h": "S + be + place",
          "s": "The wound is on his leg."
        },
        {
          "p": "Is the wound bleeding?",
          "m": "Trả lời có hoặc không, dùng 'bleeding' hoặc 'no'.",
          "h": "S + be + V/Adj hoặc S + V(s) + O",
          "s": "Yes, it is bleeding."
        },
        {
          "p": "How big is the wound?",
          "m": "Mô tả ngắn kích thước: small/large.",
          "h": "S + be + small/large",
          "s": "The wound is small."
        },
        {
          "p": "Can you see any blood on clothes?",
          "m": "Trả lời có/không ngắn gọn.",
          "h": "S + can/can't + V or There is/are",
          "s": "Yes, there is blood on his shirt."
        },
        {
          "p": "Do you think the wound is serious?",
          "m": "Nói có/không ngắn và lý do ngắn (1 cụm).",
          "h": "S + think + S + be + Adj or S + can/can't + V",
          "s": "Yes, I think it is serious."
        }
      ]
    },
    {
