// Prisma 7: datasource URL được inject qua prisma.config.ts
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Phân loại chủ đề lớn (Ví dụ: Everyday, Office, Niche)
enum CategoryType {
  EVERYDAY
  OFFICE
  NICHE
}

/// Trạng thái hiển thị của một bộ bài tập
enum PackStatus {
  DRAFT // Đang soạn thảo, chưa hiện cho người dùng
  PUBLISHED // Đã xuất bản, người dùng có thể học
  ARCHIVED // Đã lưu trữ, không hiển thị nữa
}

/// Danh mục chính của nội dung học tập
model Category {
  id          String       @id @default(uuid())
  code        String? /// Mã danh mục (nếu có)
  name        String /// Tên danh mục (Ví dụ: Tiếng Anh Giao Tiếp)
  type        CategoryType /// Loại danh mục (Hàng ngày, Công sở...)
  subCategory String? /// Phân loại con cho Niche (Ví dụ: HEALTHCARE, IT...)
  order       Int          @default(0) /// Thứ tự hiển thị trong Type/subCategory
  description String? /// Mô tả chi tiết về danh mục

  topics      Topic[]
  lessonPacks LessonPack[]

  @@unique([name, type, subCategory])
  @@map("categories")
}

/// Định nghĩa các cấp độ học thuật (1-Beginner, 2-Elementary, ...)
model Level {
  id                 Int     @id /// Số thứ tự cấp độ (1, 2, 3, 4)
  description        String? /// Mô tả cấp độ (ví dụ: Người mới bắt đầu...)
  passThresholdScore Int /// Điểm tối thiểu để coi là hoàn thành (Ví dụ: 60)
  outputRequirements Json /// Cấu trúc yêu cầu đầu ra phức tạp (ngữ pháp, từ vựng...)
  examples           Json    @default("[]") /// Danh sách ví dụ minh họa (mảng object)

  topics      Topic[]
  lessonPacks LessonPack[]

  @@map("levels")
}

/// Chủ đề cụ thể thuộc một Category và Level (Ví dụ: Hospital Basics)
model Topic {
  id         String @id @default(uuid())
  categoryId String /// Liên kết tới Category
  levelId    Int /// Liên kết tới Level (id)
  order      Int    @default(0) /// Thứ tự hiển thị chủ đề

  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  level       Level        @relation(fields: [levelId], references: [id], onDelete: Cascade)
  lessonPacks LessonPack[]

  @@unique([categoryId, levelId])
  @@index([categoryId])
  @@index([levelId])
  @@map("topics")
}

/// Một bộ bài tập gồm 5 câu (Exercise)
model LessonPack {
  id          String     @id @default(uuid())
  creatorId   String /// ID người tạo (Liên kết tới User Service)
  categoryId  String /// Thuộc Category nào
  levelId     Int /// Thuộc Level nào
  topicId     String /// Thuộc Topic nào
  title       String /// Tiêu đề bộ bài tập
  description String? /// Mô tả nội dung bộ bài tập
  isOfficial  Boolean    @default(false) /// Có phải bài tập do hệ thống tạo hay không
  status      PackStatus @default(DRAFT) /// Trạng thái (Draft/Published/Archived)

  totalPlays    Int   @default(0) /// Tổng số lượt người dùng đã học
  averageRating Float @default(0.0) /// Đánh giá trung bình từ người dùng

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  level        Level         @relation(fields: [levelId], references: [id], onDelete: Cascade)
  topic        Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  exercises    Exercise[]
  packAttempts PackAttempt[]

  @@index([creatorId])
  @@index([categoryId, levelId, status])
  @@index([topicId, status])
  @@map("lesson_packs")
}

/// Một câu bài tập cụ thể trong Lesson Pack
model Exercise {
  id             String  @id @default(uuid())
  lessonPackId   String /// Liên kết tới Lesson Pack cha
  sequenceOrder  Int /// Thứ tự câu (1 đến 5)
  previousPrompt String? /// Nội dung đối phương nói (English)
  myPrompt       String /// Nội dung người dùng cần diễn tả (Vietnamese)
  levelHint      String? /// Gợi ý hoặc ghi chú về ngữ pháp/từ vựng

  lessonPack LessonPack        @relation(fields: [lessonPackId], references: [id], onDelete: Cascade)
  attempts   ExerciseAttempt[]

  @@unique([lessonPackId, sequenceOrder])
  @@index([lessonPackId])
  @@map("exercises")
}

model ExerciseAttempt {
  id            String        @id @default(uuid())
  exerciseId    String
  userId        String
  packAttemptId String?
  audioPath     String? // S3 key (path) — resolve từ media-service
  durationMs    Int?
  transcript    String? // text từ Whisper
  status        AttemptStatus @default(PENDING)
  createdAt     DateTime      @default(now())

  exercise    Exercise     @relation(fields: [exerciseId], references: [id])
  packAttempt PackAttempt? @relation(fields: [packAttemptId], references: [id])

  @@index([userId, exerciseId])
  @@index([packAttemptId])
  @@map("exercise_attempts")
}

model PackAttempt {
  id           String            @id @default(uuid())
  userId       String
  lessonPackId String
  status       PackAttemptStatus @default(IN_PROGRESS)
  startedAt    DateTime          @default(now())
  completedAt  DateTime?

  // Scoring (Tầng 2 — nullable, chỉ có khi user chọn AI feedback)
  scoringStatus ScoringStatus?
  overallScore  Int? // 0–100
  passed        Boolean?
  scoringMode   ScoringMode?
  scoredAt      DateTime?
  aiResponseRaw Json? // Raw JSON từ AI (debug/audit)

  lessonPack     LessonPack        @relation(fields: [lessonPackId], references: [id])
  exerciseScores ExerciseScore[]
  attempts       ExerciseAttempt[]

  @@index([userId, lessonPackId])
  @@map("pack_attempts")
}

model ExerciseScore {
  id                 String  @id @default(uuid())
  packAttemptId      String
  exerciseId         String
  sequenceOrder      Int
  score              Int // 0–100
  criterion1Score    Int // Relevance (FREE) hoặc TaskCompletion (GUIDED)
  criterion1Feedback String?
  grammarScore       Int
  grammarFeedback    String?
  vocabScore         Int
  vocabFeedback      String?
  tasks              Json? // [{task, completed}] — chỉ mode GUIDED
  suggestedPhrases   Json? // string[] — chỉ mode FREE, L2 & L3

  packAttempt PackAttempt @relation(fields: [packAttemptId], references: [id])

  @@index([packAttemptId])
  @@map("exercise_scores")
}

enum AttemptStatus {
  PENDING // audio uploaded, chưa transcript
  TRANSCRIBED // Whisper xong
  TRANSCRIPT_FAILED
}

enum PackAttemptStatus {
  IN_PROGRESS // user đang làm pack
  COMPLETED // tất cả exercises đã transcript
  SCORING // đang chờ AI scoring
  SCORED // AI scoring xong
}

enum ScoringStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ScoringMode {
  FREE
  GUIDED
}
